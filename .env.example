# Environment variable template for the Memorang AI Learning Agent.
# Copy this file to `.env.local` and replace each placeholder with a real value.
# Never commit real credentials — the placeholders below are descriptive tokens only.

# Purpose: Gemini API key used by the agent and CopilotKit tutor to call
#          the language model. Consumed by /api/agent and /api/copilotkit.
# Required: yes (unless using Groq exclusively)
GEMINI_API_KEY=your_gemini_api_key_here

# Purpose: Groq API key used as an alternative AI provider when Gemini hits
#          rate limits. Get a free key at https://console.groq.com/keys
# Required: no (optional alternative to Gemini)
GROQ_API_KEY=your_groq_api_key_here

# Purpose: Public URL the CopilotKit React provider uses to reach the runtime
#          endpoint. When unset, the provider defaults to the same-origin
#          `/api/copilotkit` route.
# Required: no (optional)
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=<http://localhost:3000/api/copilotkit>